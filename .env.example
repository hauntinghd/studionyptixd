# Polymarket API Credentials (Required for Live Trading)
# For the Shadow Watcher phase, you can leave these blank or use placeholders.
# To generate these, go to https://polymarket.com/settings/api-keys

POLY_ADDRESS=0xYourPublicAddress
POLY_API_KEY=your_api_key
POLY_API_SECRET=your_api_secret
POLY_API_PASSPHRASE=your_api_passphrase

# Mr. $ Bot Notification URL (Webhook)
MR_DOLLAR_WEBHOOK=https://your-mr-dollar-bot-webhook.com/status
