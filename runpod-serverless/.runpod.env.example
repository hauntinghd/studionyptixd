# Copy this file to .runpod.env and fill in values.
# .runpod.env is gitignored — NEVER commit real secrets here.
#
# Required for deploy.sh:
RUNPOD_API_KEY=                         # runpod.io/console/user/settings → API Keys → create a full-permission key
DOCKER_REGISTRY=docker.io/caseynyptid   # or ghcr.io/crypticsciencee — where the image will live
IMAGE_TAG=studio-backend:v1.0

# Strongly recommended — persistent state (PayPal orders, topup wallets,
# projects, longform sessions). Create via RunPod dashboard → Storage → Network
# Volumes → New. 10 GB is plenty for Studio; $0.07/GB/mo. Copy the volume ID here.
NETWORK_VOLUME_ID=
STUDIO_APP_DATA_DIR=/runpod-volume/studio

# ─── Secrets baked into the serverless template ───
# deploy.sh reads these from .runpod.env (or the current shell) and passes them
# to the RunPod template. Values live inside RunPod, not in git.

# AI providers
XAI_API_KEY=
ELEVENLABS_API_KEY=
FAL_AI_KEY=
PIKZELS_API_KEY=
ALGROW_API_KEY=
COMFYUI_URL=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_KEY=

# Google / YouTube OAuth
YOUTUBE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.studio.nyptidindustries.com/api/youtube/callback

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=live
PAYPAL_WEBHOOK_ID=

# Public domain the backend lives behind (for CORS + redirects + webhooks)
SITE_URL=https://studio.nyptidindustries.com

# Optional: RunPod GPU compositor endpoint — only if you want to wire the
# GPU-heavy compositor/ComfyUI into this serverless backend.
RUNPOD_COMPOSITOR_ENABLED=false
RUNPOD_COMPOSITOR_ENDPOINT_ID=

# ─── Populated automatically by deploy.sh ───
# RUNPOD_ENDPOINT_ID=   (deploy.sh appends this after success)
